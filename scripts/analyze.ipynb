    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "df = pd.read_csv(\"user_logs_export.csv\")\n",
    "plt.subplot(2 , 1  ,1)\n",
    "plt.bar(df[\"user_id\"], df[\"avg_time\"])\n",
    "plt.xlabel(\"USER_ID\")\n",
    "plt.ylabel(\"V\")\n",
    "plt.title(\"Daily Page Visits\")\n",
    "plt.xticks(rotation=45)\n",
    "plt.show()"
   ]
